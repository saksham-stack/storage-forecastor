# ============================================================
# Application Environment
# ============================================================
APP_ENV=development
# Options: development, staging, production
APP_BASE_URL=http://localhost:8501

# ============================================================
# Database Configuration
# ============================================================

# Option 1: SQLite (Local Development - Default)
# DATABASE_URL=sqlite:///data/app_reviews.db

# Option 2: PostgreSQL (Local via Docker Compose)
DATABASE_URL=postgresql+psycopg://app_user:app_password@localhost:5432/storage_forecaster

# Option 3: Neon (Managed PostgreSQL - Recommended)
# DATABASE_URL=postgresql+psycopg://user:password@[host].neon.tech:5432/neondb

# Option 4: Supabase (Managed PostgreSQL + extras)
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres

# Option 5: Railway (Managed Postgres)
# DATABASE_URL will be auto-populated by Railway

# Option 6: Render (Managed Postgres)
# DATABASE_URL will be auto-populated by Render

# ============================================================
# Docker & PostgreSQL Configuration
# ============================================================
# Only needed for docker-compose
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=storage_forecaster
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ============================================================
# Optional: Observability & Monitoring
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# POSTHOG_API_KEY=your-posthog-api-key
# LOG_LEVEL=INFO
